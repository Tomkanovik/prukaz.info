---
---

<section id="kontakt" class="contact-section py-12 md:py-24 bg-gray-50">
  <div class="wrapper">
    <div class="bg-white rounded-[2rem] md:rounded-[3rem] shadow-xl overflow-hidden">
      <div class="grid md:grid-cols-2">
        <div class="p-6 md:p-16 lg:p-20 stack" style="--space: 2.5rem;">
          <div class="stack" style="--space: 1rem;">
            <h2 class="text-3xl md:text-4xl font-bold text-gray-900">Kontaktujte mě</h2>
            <p class="text-lg text-gray-600">
              Máte dotaz nebo zájem o spolupráci? Neváhejte se mi ozvat, rád vám pomohu s vaším projektem.
            </p>
          </div>

          <div class="stack" style="--space: 1.5rem;">
            <div class="flex items-center gap-5">
              <div class="w-12 h-12 bg-green-700 text-white rounded-xl flex items-center justify-center shrink-0">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
                </svg>
              </div>
              <div>
                <span class="block text-sm text-gray-500 font-bold uppercase tracking-wider">Telefon</span>
                <a href="tel:+420724697448" class="text-xl md:text-2xl font-bold text-gray-900 hover:text-green-700 transition-colors">+420 724 697 448</a>
              </div>
            </div>

            <div class="flex items-center gap-5">
              <div class="w-12 h-12 bg-green-700 text-white rounded-xl flex items-center justify-center shrink-0">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
                </svg>
              </div>
              <div class="min-w-0">
                <span class="block text-sm text-gray-500 font-bold uppercase tracking-wider">E-mail</span>
                <a href="mailto:energ.auditor@seznam.cz" class="text-lg md:text-xl font-bold text-gray-900 hover:text-green-700 transition-colors break-all">energ.auditor@seznam.cz</a>
              </div>
            </div>
          </div>

          <div class="p-6 bg-green-50 rounded-2xl border border-green-100">
             <p class="text-green-800 font-medium">
                Působím především v <span class="font-bold">Praze a Středočeském kraji</span>, po domluvě však v rámci celé ČR.
             </p>
          </div>
        </div>
        <div class="p-6 md:p-16 lg:p-20 bg-gray-50/50 border-t md:border-t-0 md:border-l border-gray-100">
           <form id="contact-form" class="contact-form">
              <div class="form-group">
                <label for="name">Jméno a příjmení</label>
                <input type="text" id="name" name="name" required placeholder="Vaše jméno" />
              </div>
              <div class="form-group">
                <label for="email">E-mail</label>
                <input type="email" id="email" name="email" required placeholder="vas@email.cz" />
              </div>
              <div class="form-group">
                <label for="message">Zpráva</label>
                <textarea id="message" name="message" required placeholder="S čím vám mohu pomoci?"></textarea>
              </div>
              <button type="submit" id="submit-button">Odeslat zprávu</button>
              <div id="form-status" class="form-status"></div>
           </form>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement;
  const statusDiv = document.getElementById('form-status');
  const submitButton = document.getElementById('submit-button') as HTMLButtonElement;

  if (form && statusDiv && submitButton) {
    form.addEventListener('submit', async (e) => {
      e.preventDefault();

      const formData = new FormData(form);
      const data = Object.fromEntries(formData.entries());

      // Reset status
      statusDiv.textContent = '';
      statusDiv.className = 'form-status';
      submitButton.disabled = true;
      submitButton.textContent = 'Odesílám...';

      try {
        const response = await fetch('/api/send-email', {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json',
          },
          body: JSON.stringify(data),
        });

        const result = await response.json();

        if (response.ok) {
          form.reset();
          form.style.display = 'none';

          const successWrapper = document.createElement('div');
          successWrapper.className = 'stack';
          successWrapper.style.setProperty('--space', '1rem');

          const formTitle = document.createElement('h3');
          formTitle.className = 'text-2xl font-bold text-gray-900';
          formTitle.textContent = 'Zpráva byla odeslána';

          const successMsg = document.createElement('p');
          successMsg.className = 'text-lg text-gray-600';
          successMsg.textContent = 'Děkujeme za zprávu! Ozvu se vám hned, jak to bude možné.';

          successWrapper.appendChild(formTitle);
          successWrapper.appendChild(successMsg);
          form.parentElement?.prepend(successWrapper);
        } else {
          statusDiv.textContent = result.error || 'Něco se nepovedlo. Zkuste to prosím později nebo využijte telefonní kontakt.';
          statusDiv.classList.add('is-visible', 'is-error');
        }
      } catch (error) {
        console.error('Form error:', error);
        statusDiv.textContent = 'Chyba při odesílání. Zkontrolujte prosím své připojení k internetu nebo to zkuste později.';
        statusDiv.classList.add('is-visible', 'is-error');
      } finally {
        submitButton.disabled = false;
        submitButton.textContent = 'Odeslat zprávu';
      }
    });
  }
</script>
