---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Contact from '../components/Contact.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="Orientační ceník - Ing. Petr Novák">
  <Header />

  <main>
    <section class="py-12 md:py-20">
      <div class="wrapper stack" style="--space: 3rem;">
        <div class="grid md:grid-cols-2 gap-8 md:gap-12 items-center">
          <div class="stack" style="--space: 1.5rem;">
            <div class="badge bg-green-100 text-green-800 px-4 py-1 rounded-full text-sm font-bold inline-block w-fit uppercase tracking-wide">
              Transparentní ceny
            </div>
            <h1 class="text-3xl md:text-4xl font-bold">Ceník služeb PENB</h1>
            <p class="text-xl text-gray-600 leading-relaxed">
              Poskytujeme odborné zpracování průkazů energetické náročnosti budov s důrazem na přesnost, rychlost a férové jednání. Níže naleznete orientační ceny dle typu objektu a dodaných podkladů.
            </p>
            <div class="flex items-center gap-3 text-gray-500 bg-gray-50 p-4 rounded-xl w-fit">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
              <span class="text-sm">Uvedené ceny jsou bez DPH.</span>
            </div>
          </div>
          <div class="bg-gray-100 rounded-3xl aspect-video flex items-center justify-center overflow-hidden shadow-lg border border-gray-100">
             <img src="/images/modern-building.jpg" alt="Detail moderní úsporné budovy" class="w-full h-full object-cover" />
          </div>
        </div>

        <div class="stack" style="--space: 2rem;">
          <div class="flex items-center gap-4">
             <div class="w-10 h-10 md:w-12 md:h-12 bg-green-700 text-white rounded-xl flex items-center justify-center shrink-0">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 md:h-6 md:w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6" />
                </svg>
             </div>
             <h2 class="text-2xl md:text-3xl font-bold text-gray-900">Rodinné domy a jednotlivé byty</h2>
          </div>

          <div class="overflow-x-auto">
            <table class="w-full text-left border-collapse">
              <thead>
                <tr class="bg-gray-50 border-b border-gray-200">
                  <th class="py-6 px-8 font-bold text-gray-900 uppercase tracking-wider text-sm">Objekt / Podklady</th>
                  <th class="py-6 px-8 font-bold text-gray-900 uppercase tracking-wider text-sm text-center">Rodinný dům jednopodlažní</th>
                  <th class="py-6 px-8 font-bold text-gray-900 uppercase tracking-wider text-sm text-center">Rodinný dům vícepodlažní</th>
                </tr>
              </thead>
              <tbody class="divide-y divide-gray-200">
                <tr>
                  <td class="py-8 px-8 font-semibold text-gray-900">Kompletní projektová dokumentace</td>
                  <td class="py-8 px-8 text-center text-2xl font-bold text-green-700">3 000 Kč</td>
                  <td class="py-8 px-8 text-center text-2xl font-bold text-green-700">3 500 Kč</td>
                </tr>
                <tr>
                  <td class="py-8 px-8 font-semibold text-gray-900">Podklady žádné</td>
                  <td class="py-8 px-8 text-center text-2xl font-bold text-green-700">3 300 Kč</td>
                  <td class="py-8 px-8 text-center text-2xl font-bold text-green-700">3 900 Kč</td>
                </tr>
              </tbody>
            </table>
          </div>
          <p class="text-sm text-gray-500 italic text-right">Pozn.: Uvedené ceny jsou bez DPH.</p>
        </div>

        <div class="stack" style="--space: 2rem;">
          <div class="flex items-center gap-4">
             <div class="w-10 h-10 md:w-12 md:h-12 bg-green-700 text-white rounded-xl flex items-center justify-center shrink-0">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 md:h-6 md:w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4" />
                </svg>
             </div>
             <h2 class="text-2xl md:text-3xl font-bold text-gray-900">Bytové domy a veřejné budovy</h2>
          </div>

          <div class="grid md:grid-cols-3 gap-8">
             {[
               { title: 'Rychlé dodání', desc: 'PENB zpracujeme obvykle do 3-5 pracovních dnů od předání podkladů.' },
               { title: 'Kompletní dokumentace', desc: 'Cena zahrnuje tištěné vyhotovení i elektronickou verzi v PDF.' },
               { title: 'Doprava v ceně', desc: 'V rámci regionu je doprava specialisty na místo zahrnuta v paušálu.' }
             ].map(item => (
               <div class="bg-gray-50 p-8 rounded-2xl stack" style="--space: 1rem;">
                  <h3 class="font-bold text-lg text-gray-900">{item.title}</h3>
                  <p class="text-gray-600">{item.desc}</p>
               </div>
             ))}
          </div>

          <div class="overflow-x-auto">
            <table class="w-full text-left border-collapse">
              <thead>
                <tr class="bg-gray-50 border-b border-gray-200">
                  <th class="py-6 px-8 font-bold text-gray-900 uppercase tracking-wider text-sm">Objekt / Podklady</th>
                  <th class="py-6 px-8 font-bold text-gray-900 uppercase tracking-wider text-sm text-center">Bytový dům cca 10 bytů <span class="block text-[10px] normal-case font-normal">(cena od)</span></th>
                  <th class="py-6 px-8 font-bold text-gray-900 uppercase tracking-wider text-sm text-center">Bytový dům cca 20 a více bytů <span class="block text-[10px] normal-case font-normal">(cena od)</span></th>
                  <th class="py-6 px-8 font-bold text-gray-900 uppercase tracking-wider text-sm text-center">Veřejná budova jednoduchá <span class="block text-[10px] normal-case font-normal">(cena od)</span></th>
                  <th class="py-6 px-8 font-bold text-gray-900 uppercase tracking-wider text-sm text-center">Veřejná budova členitá <span class="block text-[10px] normal-case font-normal">(cena od)</span></th>
                </tr>
              </thead>
              <tbody class="divide-y divide-gray-200">
                <tr>
                  <td class="py-8 px-8 font-semibold text-gray-900">Kompletní projektová dokumentace</td>
                  <td class="py-8 px-8 text-center text-xl font-bold text-green-700">4 200 Kč</td>
                  <td class="py-8 px-8 text-center text-xl font-bold text-green-700">7 150 Kč</td>
                  <td class="py-8 px-8 text-center text-xl font-bold text-green-700">5 700 Kč</td>
                  <td class="py-8 px-8 text-center text-xl font-bold text-green-700">8 500 Kč</td>
                </tr>
                <tr>
                  <td class="py-8 px-8 font-semibold text-gray-900">Podklady žádné</td>
                  <td class="py-8 px-8 text-center text-xl font-bold text-green-700">5 700 Kč</td>
                  <td class="py-8 px-8 text-center text-xl font-bold text-green-700">8 500 Kč</td>
                  <td class="py-8 px-8 text-center text-xl font-bold text-green-700">7 150 Kč</td>
                  <td class="py-8 px-8 text-center text-xl font-bold text-green-700">9 900 Kč</td>
                </tr>
              </tbody>
            </table>
          </div>
          <p class="text-sm text-gray-500 italic text-right">Pozn.: Uvedené ceny jsou bez DPH.</p>
        </div>

      </div>
    </section>
  </main>

  <Contact />
  <Footer />
</Layout>
