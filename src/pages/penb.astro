---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Contact from '../components/Contact.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="Kdy je povinný PENB - Ing. Petr Novák">
  <Header />

  <main>
    <section class="py-12 md:py-20">
      <div class="wrapper stack" style="--space: 3rem;">
        <div class="stack" style="--space: 1.5rem; max-width: 800px;">
          <h1 class="text-3xl md:text-4xl font-bold italic underline decoration-green-500 underline-offset-8">Kdy je povinný PENB?</h1>
          <p class="text-xl text-gray-600">
            Průkaz energetické náročnosti budovy je zákonným požadavkem v mnoha situacích. Zde je přehled těch nejdůležitějších:
          </p>
        </div>

        <div class="grid lg:grid-cols-3 gap-8 md:gap-12 items-start">
          <div class="lg:col-span-2 grid gap-8 md:gap-12">
          {[
            {
              title: 'Výstavba nových budov',
              desc: 'PENB je povinnou součástí dokumentace pro stavební povolení nebo ohlášení stavby u všech nových budov.'
            },
            {
              title: 'Větší změny dokončených budov',
              desc: 'Při rekonstrukcích, které ovlivňují více než 25 % celkové plochy obálky budovy (např. zateplení, výměna oken, oprava střechy).'
            },
            {
              title: 'Prodej nebo pronájem budovy',
              desc: 'Vlastník budovy je povinen zajistit PENB při prodeji nebo pronájmu celé budovy.'
            },
            {
              title: 'Prodej nebo pronájem ucelené části budovy (bytu)',
              desc: 'Při prodeji nebo pronájmu bytu je povinnost doložit PENB pro celou budovu. Pokud není k dispozici, lze jej nahradit vyúčtováním dodávek energií za poslední 3 roky.'
            }
          ].map((item, index) => (
            <div class="flex flex-col sm:flex-row gap-4 md:gap-8 items-start">
              <div class="text-4xl font-black text-green-100 select-none">
                {String(index + 1).padStart(2, '0')}
              </div>
              <div class="stack" style="--space: 0.5rem;">
                <h3 class="text-xl md:text-2xl font-bold text-gray-900">{item.title}</h3>
                <p class="text-lg text-gray-600 leading-relaxed max-w-4xl">{item.desc}</p>
              </div>
            </div>
          ))}
          </div>
          <div class="hidden lg:block sticky top-8">
            <div class="rounded-3xl overflow-hidden shadow-xl aspect-[4/5]">
              <img src="/images/modern-building.jpg" alt="Moderní energeticky úsporná budova" class="w-full h-full object-cover" />
            </div>
          </div>
        </div>

        <div class="bg-yellow-50 border-l-4 border-yellow-400 p-6 md:p-8 rounded-r-xl mt-8 md:mt-12">
          <div class="flex flex-col sm:flex-row gap-4 items-start">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8 text-yellow-600 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m-9.303 3.376c-.866 1.5.217 3.374 1.948 3.374h14.71c1.73 0 2.813-1.874 1.948-3.374L13.949 3.378c-.866-1.5-3.032-1.5-3.898 0L2.697 16.126ZM12 15.75h.007v.008H12v-.008Z" />
            </svg>
            <div class="stack" style="--space: 0.5rem;">
              <h4 class="font-bold text-yellow-800 text-lg">Výjimky z povinnosti</h4>
              <p class="text-yellow-700">
                PENB se nemusí zpracovávat například pro budovy s celkovou energeticky vztažnou plochou menší než 50 m², budovy pro rodinnou rekreaci (chaty, chalupy) nebo památkově chráněné objekty (v určitých případech).
              </p>
            </div>
          </div>
        </div>
      </div>
    </section>
  </main>

  <Contact />
  <Footer />
</Layout>
