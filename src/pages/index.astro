---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Contact from '../components/Contact.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="Ing. Petr Novák - Energetický specialista">
	<Header />

	<main>
		<!-- Hero Section -->
		<section class="hero-section py-12 md:py-20">
			<div class="wrapper">
				<div class="grid md:grid-cols-2 gap-8 md:gap-12 items-center">
					<div class="stack" style="--space: 2rem;">
						<div class="badge bg-green-100 text-green-800 px-4 py-1 rounded-full text-sm font-bold inline-block w-fit uppercase tracking-wide">
							Odbornost a zkušenost
						</div>
						<h1 class="text-4xl md:text-5xl font-bold leading-tight">
							Snižte náklady na energie s <span class="text-green-700">profesionálem</span>
						</h1>
						<p class="text-xl text-gray-600 leading-relaxed">
							Zpracuji pro vás Průkaz energetické náročnosti budovy (PENB) rychle, kvalitně a za férovou cenu. Pomohu vám se zorientovat v dotačních titulech.
						</p>
						<div class="cluster" style="--gutter: 1rem;">
							<a href="/sluzby" class="bg-green-700 text-white px-8 py-4 rounded-lg font-bold hover:bg-green-800 transition-colors">Naše služby</a>
							<a href="#kontakt" class="border-2 border-green-700 text-green-700 px-8 py-4 rounded-lg font-bold hover:bg-green-50 transition-colors">Kontaktujte mě</a>
						</div>
					</div>
					<div class="relative">
						<div class="bg-gray-200 rounded-2xl aspect-video overflow-hidden shadow-2xl">
							<img src="/images/hero-energy.jpg" alt="Energetický specialista při práci s tabletem" class="w-full h-full object-cover" loading="eager" />
						</div>
						<div class="absolute -bottom-6 -right-6 bg-white p-4 rounded-xl shadow-lg hidden lg:block border border-gray-100">
							<div class="flex items-center gap-3">
								<div class="bg-green-100 p-2 rounded-lg text-green-700">
									<svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
										<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
									</svg>
								</div>
								<div>
									<p class="text-sm font-bold text-gray-900">Certifikovaný specialista</p>
								</div>
							</div>
						</div>
					</div>
				</div>
			</div>
		</section>

		<!-- Co je to PENB -->
		<section class="bg-gray-50 py-12 md:py-20">
			<div class="wrapper stack" style="--space: 3rem;">
				<div class="max-w-3xl">
					<h2 class="text-2xl md:text-3xl font-bold mb-4 md:mb-6">Co je to PENB a proč ho potřebujete?</h2>
					<p class="text-lg text-gray-600">
						Průkaz energetické náročnosti budovy (PENB) informuje o energetické náročnosti budovy. Je nezbytným dokumentem při prodeji, pronájmu nebo výstavbě nemovitosti.
					</p>
				</div>

				<div class="grid md:grid-cols-3 gap-8">
					{[
						{ title: 'Při prodeji', desc: 'Zákonná povinnost pro majitele nemovitosti při jejím prodeji.' },
						{ title: 'Při pronájmu', desc: 'Od roku 2016 je povinný i při pronájmu bytů a domů.' },
						{ title: 'Při výstavbě', desc: 'Nezbytná součást projektové dokumentace pro stavební povolení.' }
					].map(item => (
						<div class="bg-white p-8 rounded-xl shadow-sm stack" style="--space: 1rem;">
							<div class="w-12 h-12 bg-green-100 rounded-full flex items-center justify-center text-green-700">
								<svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
									<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
								</svg>
							</div>
							<h3 class="text-xl font-bold">{item.title}</h3>
							<p class="text-gray-600">{item.desc}</p>
						</div>
					))}
				</div>
			</div>
		</section>

		<!-- Proč si vybrat mě -->
		<section class="py-12 md:py-20">
			<div class="wrapper">
				<div class="bg-green-700 rounded-3xl p-8 md:p-12 text-white stack" style="--space: 2rem;">
					<h2 class="text-2xl md:text-3xl font-bold">Proč spolupracovat právě se mnou?</h2>
					<ul class="grid sm:grid-cols-2 gap-x-12 gap-y-6" style="--space: 1.5rem;">
						{[
							'Individuální a férový přístup',
							'Dlouholetá praxe v oboru',
							'Rychlé zpracování do 5-7 pracovních dnů',
							'Certifikace Ministerstva průmyslu a obchodu'
						].map(item => (
							<li class="flex items-center gap-4">
								<div class="bg-green-600 rounded-full p-1 shrink-0">
									<svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor">
										<path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
									</svg>
								</div>
								<span class="text-lg">{item}</span>
							</li>
						))}
					</ul>
				</div>
			</div>
		</section>
	</main>

	<Contact />
	<Footer />
</Layout>

<style>
</style>
